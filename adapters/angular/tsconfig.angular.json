{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "outDir": "build/angular",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "declaration": true,
    "sourceMap": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "angularCompilerOptions": {
    "compilationMode": "partial",
    "strictTemplates": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
